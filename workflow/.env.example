# HappyRobot workflow build — credentials & config.
# COPY this file to `workflow/.env` (git-ignored) and fill in the real values.
# Scripts in workflow/ read `workflow/.env`; secrets are never printed or committed.

# HappyRobot Public API bearer key (Settings > API Keys). Needs workflow + voice scopes.
HR_API_KEY=hr_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HappyRobot Public API base. Leave as-is unless you're on a non-prod cluster.
HR_BASE_URL=https://platform.happyrobot.ai/api/v2

# The adapter bearer the workflow's Webhook tools will send (your Railway ADAPTER_API_KEY).
# Used to set the HappyRobot env var @env.ADAPTER_API_KEY. Never enters git.
ADAPTER_API_KEY=

# Live adapter base URL. The Webhook tools target this.
ADAPTER_BASE_URL=https://tms-adapter-production.up.railway.app
