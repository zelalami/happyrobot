# Copy to .env (gitignored) and fill in real values. NEVER commit the real .env.

# --- Legacy TMS (issued out of band; bearer secret) ---
TMS_HOST=tramway.proxy.rlwy.net
TMS_PORT=17159
TMS_TOKEN=

# --- FMCSA carrier authority (lookup by MC#) ---
# FMCSA_SOURCE selects the live backend when USE_STUBS=false:
#   soda     = federal open data (data.transportation.gov); no key; DEFAULT + works server-to-server
#   qcmobile = keyed QCMobile API (mobile.fmcsa.dot.gov); uses FMCSA_API_KEY (edge-WAF blocks S2S today)
#   stub     = deterministic stub even when USE_STUBS=false
FMCSA_SOURCE=soda
# QCMobile webKey — only used when FMCSA_SOURCE=qcmobile
FMCSA_API_KEY=
# Optional Socrata app token for the SODA backend (raises rate limits; not required)
FMCSA_SODA_APP_TOKEN=

# --- SMS: Twilio trial (OTP delivery) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Adapter inbound auth (optional locally; SET IN DEPLOY) ---
# The Webhook node sends this as `Authorization: Bearer <ADAPTER_API_KEY>`.
# If unset, inbound auth is disabled (fine for local dev).
ADAPTER_API_KEY=

# --- Behavior ---
# true = FMCSA/SMS use deterministic stubs, no real calls/texts (reproducible demo)
USE_STUBS=false

# --- TMS transport tunables (seconds; sane defaults shown) ---
TMS_DEADLINE_S=8.0
TMS_CONNECT_TIMEOUT_S=3.0
TMS_READ_TIMEOUT_S=6.0

# --- OTP / negotiation policy (defaults shown) ---
OTP_TTL_S=300
OTP_MAX_ATTEMPTS=3
OTP_RESEND_MAX=3
NEGOTIATION_MAX_ROUNDS=3

LOG_LEVEL=INFO
